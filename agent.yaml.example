# GOPASS Agent Configuration Example

# The Master control node gRPC listener address
master_addr: "127.0.0.1:50051"

# Unique alias/name for this agent node (as referenced in Telegram command /deploy)
node_alias: "test-server-1"

# The Communication Token generated by Master to authenticate this Agent.
# You can find the active token in gopass-master's startup logs.
communication_token: "YOUR_COMMUNICATION_TOKEN_FROM_MASTER_HERE"
